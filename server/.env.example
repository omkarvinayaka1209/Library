PORT=4000
COUNTRY_CODE=+91
REMINDER_SWEEP_CRON=*/15 * * * *

# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB_NAME=vemu_library

# AI provider: openai | gemini | leave blank for built-in rule-based assistant
AI_PROVIDER=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Twilio OTP / SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_PHONE_NUMBER=
SMS_FROM_NAME=VEMU Library
